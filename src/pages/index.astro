---
import Layout from '~/layouts/PageLayout.astro';
import { getPermalink } from '~/utils/permalinks';
import { Image } from 'astro:assets';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import StructuredData from '~/components/common/StructuredData.astro';

// Import images
import edgeServerImage from '~/assets/images/local-ai-agent-edge-server-hardware.webp';
import dataPrivacyImage from '~/assets/images/secure-local-ai-infrastructure-data-privacy.webp';
import latencyImage from '~/assets/images/low-latency-local-ai-vs-cloud-comparison.webp';

const metadata = {
  title: 'LocalAI Agent - Enterprise Local AI Infrastructure & AI Agents',
  description: 'Deploy AI models locally and run enterprise-grade AI agents on your own infrastructure. Secure, private, low-latency AI solutions for businesses.',
  openGraph: {
    type: 'website',
    images: [
      {
        url: '~/assets/images/local-ai-agent-edge-server-hardware.webp',
        width: 1200,
        height: 630,
        alt: 'LocalAI Agent - Enterprise AI Infrastructure',
      },
    ],
  },
  twitter: {
    cardType: 'summary_large_image',
  },
  robots: {
    index: true,
    follow: true,
  },
};

// FAQ data for structured data
const faqs = [
  {
    question: 'What is LocalAI Agent?',
    answer: 'LocalAI Agent is an enterprise solution that helps organizations deploy AI models locally and run enterprise-grade AI agents on their own infrastructure, ensuring data privacy, security, and low-latency inference.',
  },
  {
    question: 'Why deploy AI models locally?',
    answer: 'Local AI deployment provides complete data privacy, reduced latency, lower costs, and full control over your AI infrastructure. It eliminates dependency on cloud providers and keeps sensitive enterprise data within your organization.',
  },
  {
    question: 'What AI models does LocalAI Agent support?',
    answer: 'LocalAI Agent supports a wide range of open-source LLMs including Llama, Mistral, Falcon, and other transformer-based models. Our platform is model-agnostic and optimized for enterprise deployment.',
  },
];
---

<StructuredData type="organization" />
<StructuredData type="service" />
<StructuredData type="faq" faqs={faqs} />

<style is:global>
  @keyframes gradient {
    0% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
    100% {
      background-position: 0% 50%;
    }
  }
  
  .animate-gradient {
    background-size: 200% 200%;
    animation: gradient 3s ease infinite;
  }
</style>

<Layout metadata={metadata}>
  <!-- Hero Section ******************* -->

  <section class="relative py-20 md:py-32 overflow-hidden bg-page dark:bg-dark">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <!-- Left: Content -->
        <div class="text-center lg:text-left">
          <p class="text-base text-secondary dark:text-blue-200 font-bold tracking-wide uppercase mb-4">
            Currently building. Early access coming soon.
          </p>
          <h1 class="text-5xl md:text-6xl font-bold leading-tighter tracking-tighter mb-6 bg-gradient-to-r from-blue-600 via-cyan-500 to-blue-600 bg-clip-text text-transparent animate-gradient">
            LocalAI Agent
          </h1>
          <p class="text-xl text-gray-600 dark:text-gray-300 mb-8 max-w-2xl mx-auto lg:mx-0">
            Deploy local AI models and run enterprise-grade AI agents securely on your own infrastructure.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
            <a
              href={getPermalink('/contact')}
              class="inline-flex items-center justify-center px-8 py-3 text-base font-medium rounded-md text-white bg-primary hover:bg-secondary transition-colors"
            >
              Join the Waitlist
            </a>
            <a
              href="https://twitter.com/localai67177"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center px-8 py-3 text-base font-medium rounded-md text-primary bg-white border-2 border-primary hover:bg-gray-50 dark:bg-gray-800 dark:text-white dark:border-white dark:hover:bg-gray-700 transition-colors"
            >
              Follow Us
            </a>
          </div>
        </div>

        <!-- Right: Image -->
        <div class="relative px-4">
          <Image
            src={edgeServerImage}
            alt="A high-performance compact edge AI server with glowing blue LED indicators, designed for secure local deployment of large language models in enterprise environments."
            class="rounded-lg shadow-2xl w-full h-auto"
            widths={[400, 600, 800]}
            fetchpriority="high"
            loading="eager"
            width={800}
            height={600}
            aspectRatio="4/3"
          />
          <p class="text-center text-sm text-gray-500 dark:text-gray-400 mt-3">
            LocalAI Agent — High-performance edge AI server for enterprise deployment
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Vision Section **************** -->

  <section class="relative py-16 md:py-24 overflow-hidden bg-page dark:bg-dark">
    <!-- Background Image -->
    <div class="absolute inset-0 pointer-events-none" style="min-height: 600px;">
      <Image
        src={dataPrivacyImage}
        alt="A 3D isometric illustration of a digital fortress dome protecting local enterprise servers from external cloud data leaks, representing private and secure AI infrastructure."
        class="w-full h-full object-cover opacity-40 dark:opacity-50"
        widths={[800, 1200]}
        loading="lazy"
        fetchpriority="low"
        width={1920}
        height={1080}
        aspectRatio="16/9"
      />
    </div>

    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold mb-8 bg-gradient-to-r from-blue-600 via-cyan-500 to-blue-600 bg-clip-text text-transparent">
          The Future of Enterprise AI is Local
        </h2>
        <div class="space-y-6 text-lg text-gray-600 dark:text-gray-300 bg-card/50 dark:bg-card-dark/50 backdrop-blur-sm p-8 rounded-2xl">
          <p>
            Cloud AI is powerful, but enterprises need more control over their data and infrastructure.
          </p>
          <p>
            LocalAI Agent empowers businesses to deploy AI models locally and run enterprise-grade AI agents for secure, private, and efficient workflows.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- What We Are Building ********** -->

  <Features
    title="What We Are Building"
    subtitle="Building the future of enterprise AI with local deployment and intelligent automation"
    columns={3}
    items={[
      {
        title: 'Local AI Deployment',
        description: 'Run advanced AI models directly on your own infrastructure for full control and privacy.',
        icon: 'tabler:server',
      },
      {
        title: 'Enterprise AI Agents',
        description: 'Intelligent agents that automate workflows and interact with your internal systems.',
        icon: 'tabler:robot',
      },
      {
        title: 'Hardware & Software',
        description: 'A complete stack optimized for reliable and efficient local AI deployment.',
        icon: 'tabler:cpu',
      },
    ]}
  />

  <!-- Why Local AI ****************** -->

  <section class="py-16 md:py-24 bg-page dark:bg-dark">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold mb-4">
            Why Local AI?
          </h2>
          <p class="text-lg text-gray-600 dark:text-gray-300">
            Take control of your AI infrastructure and data
          </p>
        </div>
        
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <!-- Left: Benefits List -->
          <div class="space-y-6">
            <div class="flex items-start space-x-4 p-4 rounded-xl bg-card/50 dark:bg-card-dark/50 backdrop-blur-sm transition-all duration-300 hover:bg-card/60 dark:hover:bg-card-dark/60">
              <div class="flex-shrink-0 w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center">
                <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-semibold mb-2">Data Privacy & Security</h3>
                <p class="text-gray-600 dark:text-gray-300">Keep sensitive enterprise data inside your organization.</p>
              </div>
            </div>

            <div class="flex items-start space-x-4 p-4 rounded-xl bg-card/50 dark:bg-card-dark/50 backdrop-blur-sm transition-all duration-300 hover:bg-card/60 dark:hover:bg-card-dark/60">
              <div class="flex-shrink-0 w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center">
                <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-semibold mb-2">Low Latency</h3>
                <p class="text-gray-600 dark:text-gray-300">Immediate AI responses without cloud dependency.</p>
              </div>
            </div>

            <div class="flex items-start space-x-4 p-4 rounded-xl bg-card/50 dark:bg-card-dark/50 backdrop-blur-sm transition-all duration-300 hover:bg-card/60 dark:hover:bg-card-dark/60">
              <div class="flex-shrink-0 w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center">
                <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-semibold mb-2">Full Infrastructure Control</h3>
                <p class="text-gray-600 dark:text-gray-300">Customize your AI environment for your business.</p>
              </div>
            </div>

            <div class="flex items-start space-x-4 p-4 rounded-xl bg-card/50 dark:bg-card-dark/50 backdrop-blur-sm transition-all duration-300 hover:bg-card/60 dark:hover:bg-card-dark/60">
              <div class="flex-shrink-0 w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center">
                <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z" />
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-semibold mb-2">No Cloud Dependency</h3>
                <p class="text-gray-600 dark:text-gray-300">Reduce costs and risks of cloud-based AI.</p>
              </div>
            </div>
          </div>
          
          <!-- Right: Comparison Image -->
          <div class="relative px-4">
            <Image
              src={latencyImage}
              alt="A conceptual speed comparison diagram showing the ultra-low latency of local AI model inference versus the high-latency path of cloud-based AI processing."
              class="rounded-lg shadow-xl w-full h-auto"
              widths={[400, 600, 800]}
              width={800}
              height={600}
              aspectRatio="4/3"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Detailed FAQ Section ********** -->

  <section class="py-16 md:py-24 bg-alt">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold mb-4 text-center">
          Frequently Asked Questions
        </h2>
        <p class="text-lg text-gray-600 dark:text-gray-300 mb-12 text-center">
          Get answers to common questions about LocalAI Agent and local AI deployment.
        </p>

        <div class="space-y-6">
          <div class="bg-card dark:bg-card-dark rounded-xl p-6 shadow-sm">
            <h3 class="text-xl font-semibold mb-3 text-gray-900 dark:text-white">
              What is LocalAI Agent?
            </h3>
            <p class="text-gray-600 dark:text-gray-300">
              LocalAI Agent is an enterprise solution that helps organizations deploy AI models locally and run enterprise-grade AI agents on their own infrastructure, ensuring data privacy, security, and low-latency inference.
            </p>
          </div>

          <div class="bg-card dark:bg-card-dark rounded-xl p-6 shadow-sm">
            <h3 class="text-xl font-semibold mb-3 text-gray-900 dark:text-white">
              Why deploy AI models locally?
            </h3>
            <p class="text-gray-600 dark:text-gray-300">
              Local AI deployment provides complete data privacy, reduced latency, lower costs, and full control over your AI infrastructure. It eliminates dependency on cloud providers and keeps sensitive enterprise data within your organization.
            </p>
          </div>

          <div class="bg-card dark:bg-card-dark rounded-xl p-6 shadow-sm">
            <h3 class="text-xl font-semibold mb-3 text-gray-900 dark:text-white">
              What AI models are supported?
            </h3>
            <p class="text-gray-600 dark:text-gray-300">
              LocalAI Agent supports open-source LLMs including Llama, Mistral, Falcon, and other transformer-based models. Our platform is model-agnostic and optimized for enterprise deployment.
            </p>
          </div>

          <div class="bg-card dark:bg-card-dark rounded-xl p-6 shadow-sm">
            <h3 class="text-xl font-semibold mb-3 text-gray-900 dark:text-white">
              What are the hardware requirements?
            </h3>
            <p class="text-gray-600 dark:text-gray-300">
              For 7B models, you need 8GB VRAM. For 14B models, plan for 12-16GB VRAM. NVIDIA GPUs (RTX 3090/4090 or A100) are recommended for best performance.
            </p>
          </div>

          <div class="bg-card dark:bg-card-dark rounded-xl p-6 shadow-sm">
            <h3 class="text-xl font-semibold mb-3 text-gray-900 dark:text-white">
              How is data security ensured?
            </h3>
            <p class="text-gray-600 dark:text-gray-300">
              All AI processing happens on your infrastructure. Your data never leaves your network, ensuring compliance with GDPR, HIPAA, and SOC 2.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stay Connected Section ******* -->

  <section class="py-16 md:py-24 bg-page dark:bg-dark">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold mb-6">
          Stay Connected
        </h2>
        <p class="text-lg text-gray-600 dark:text-gray-300 mb-10">
          Follow us on GitHub and Twitter to track our progress. Join our community soon on Discord and Reddit.
        </p>
        <div class="flex justify-center items-center space-x-6">
          <a 
            href="https://github.com/LocalAI-Agent" 
            target="_blank" 
            rel="noopener noreferrer"
            class="text-gray-600 dark:text-gray-300 hover:text-primary dark:hover:text-blue-400 transition-colors"
            aria-label="GitHub"
          >
            <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
            </svg>
          </a>
          <a 
            href="https://twitter.com/localai67177" 
            target="_blank" 
            rel="noopener noreferrer"
            class="text-gray-600 dark:text-gray-300 hover:text-primary dark:hover:text-blue-400 transition-colors"
            aria-label="Twitter"
          >
            <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
            </svg>
          </a>
          <span class="text-gray-400 dark:text-gray-500" title="Coming soon" aria-label="Discord - Coming soon">
            <svg class="w-8 h-8 opacity-50" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
            </svg>
          </span>
          <span class="text-gray-400 dark:text-gray-500" title="Coming soon" aria-label="Reddit - Coming soon">
            <svg class="w-8 h-8 opacity-50" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 0 1 .042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 0 1 4.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 0 1 .14-.197.35.35 0 0 1 .238-.042l2.906.617a1.214 1.214 0 0 1 1.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 0 0-.231.094.33.33 0 0 0 0 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 0 0 .029-.463.33.33 0 0 0-.464 0c-.547.533-1.684.73-2.512.73-.828 0-1.979-.196-2.512-.73a.326.326 0 0 0-.232-.095z"/>
            </svg>
          </span>
        </div>
      </div>
    </div>
  </section>
</Layout>
