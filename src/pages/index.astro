---
import Layout from '~/layouts/PageLayout.astro';
import { getPermalink } from '~/utils/permalinks';
import { Image } from 'astro:assets';

import Features from '~/components/widgets/Features.astro';
import StructuredData from '~/components/common/StructuredData.astro';

// Import images
import edgeServerImage from '~/assets/images/local-ai-agent-edge-server-hardware.webp';
import dataPrivacyImage from '~/assets/images/secure-local-ai-infrastructure-data-privacy.webp';
import latencyImage from '~/assets/images/low-latency-local-ai-vs-cloud-comparison.webp';

const metadata = {
  title: 'LocalAI Agent - Enterprise Local AI Infrastructure & AI Agents',
  description:
    'Deploy AI models locally and run enterprise-grade AI agents on your own infrastructure. Secure, private, low-latency AI solutions for businesses.',
  openGraph: {
    type: 'website',
    images: [
      {
        url: '~/assets/images/local-ai-agent-edge-server-hardware.webp',
        width: 1200,
        height: 630,
        alt: 'LocalAI Agent - Enterprise AI Infrastructure',
      },
    ],
  },
  twitter: {
    cardType: 'summary_large_image',
  },
  robots: {
    index: true,
    follow: true,
  },
};

// FAQ data for structured data
const faqs = [
  {
    question: 'What is LocalAI Agent?',
    answer:
      'LocalAI Agent is an enterprise solution that helps organizations deploy AI models locally and run enterprise-grade AI agents on their own infrastructure, ensuring data privacy, security, and low-latency inference.',
  },
  {
    question: 'Why deploy AI models locally?',
    answer:
      'Local AI deployment provides complete data privacy, reduced latency, lower costs, and full control over your AI infrastructure. It eliminates dependency on cloud providers and keeps sensitive enterprise data within your organization.',
  },
  {
    question: 'What AI models does LocalAI Agent support?',
    answer:
      'LocalAI Agent supports a wide range of open-source LLMs including Llama, Mistral, Falcon, and other transformer-based models. Our platform is model-agnostic and optimized for enterprise deployment.',
  },
];
---

<StructuredData type="organization" />
<StructuredData type="service" />
<StructuredData type="faq" faqs={faqs} />

<style is:global>
  @keyframes gradient {
    0% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
    100% {
      background-position: 0% 50%;
    }
  }

  .animate-gradient {
    background-size: 200% 200%;
    animation: gradient 3s ease infinite;
  }
</style>

<Layout metadata={metadata}>
  <!-- Hero Section ******************* -->

  <section
    class="relative py-20 md:py-32 overflow-hidden bg-transparent"
    style="min-height: 800px; contain: layout style;"
  >
    <!-- Enhanced Background - Ceramic White to White gradient -->
    <div
      class="absolute inset-0 bg-gradient-to-br from-ceramic/50 via-white/30 to-ceramic/50 dark:from-obsidian/50 dark:via-gray-950/30 dark:to-obsidian/50 animate-gradient-slow backdrop-blur-sm"
      style="background-size: 200% 200%;"
    >
    </div>

    <!-- Cyber glow lines - Dark mode data flow -->
    <div class="absolute inset-0 cyber-lines opacity-30 dark:opacity-60"></div>

    <!-- Decorative floating orbs with fresnel effect -->
    <div
      class="absolute -top-40 -right-40 w-80 h-80 bg-gradient-to-br from-klein/20 to-electric-cyan/20 rounded-full blur-3xl animate-float fresnel-light"
    >
    </div>
    <div
      class="absolute -bottom-40 -left-40 w-80 h-80 bg-gradient-to-tr from-purple-500/20 to-klein/20 rounded-full blur-3xl animate-float-delayed fresnel-light"
    >
    </div>

    <div class="container-max mx-auto px-4 relative z-10">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <!-- Left: Content -->
        <div class="text-center lg:text-left" style="contain: layout;">
          <p
            class="text-sm sm:text-base text-klein dark:text-electric-cyan font-bold tracking-widest uppercase mb-4 animate-fade"
          >
            Currently building. Early access coming soon.
          </p>
          <h1
            class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold leading-tighter tracking-tight mb-6 text-charcoal dark:text-white"
            style="letter-spacing: -0.022em; word-wrap: break-word;"
          >
            LocalAI Agent
          </h1>
          <p
            class="text-lg sm:text-xl md:text-2xl text-secondary dark:text-gray-300 mb-8 max-w-2xl mx-auto lg:mx-0"
            style="line-height: 1.5;"
          >
            Deploy local AI models and run enterprise-grade AI agents securely on your own infrastructure.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
            <a
              href={getPermalink('/contact')}
              class="group inline-flex items-center justify-center w-full sm:w-auto px-8 py-4 text-base font-semibold rounded-lg text-white bg-klein hover:bg-blue-700 transition-all duration-300 shadow-soft hover:shadow-neon-blue hover:-translate-y-0.5 whitespace-normal"
              style="border-radius: 8px;"
            >
              Join the Waitlist
              <svg
                class="ml-2 w-5 h-5 group-hover:translate-x-1 transition-transform flex-shrink-0"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"
                ></path>
              </svg>
            </a>
            <a
              href="https://twitter.com/localai67177"
              target="_blank"
              rel="noopener noreferrer"
              class="group inline-flex items-center justify-center w-full sm:w-auto px-8 py-4 text-base font-semibold rounded-lg text-charcoal dark:text-white bg-white/70 dark:bg-gray-800/70 backdrop-blur-md border border-border hover:bg-white dark:hover:bg-gray-700 transition-all duration-300 shadow-soft hover:shadow-md hover:-translate-y-0.5 whitespace-normal"
              style="border-radius: 8px;"
            >
              <svg class="w-5 h-5 mr-2 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                <path
                  d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
                ></path>
              </svg>
              <span class="whitespace-nowrap">Follow Us</span>
            </a>
          </div>
        </div>

        <!-- Right: Image with glassmorphism -->
        <div class="relative" style="contain: layout;">
          <div
            class="relative glass-card rounded-lg shadow-deep mx-auto lg:mx-0 md:min-h-[400px]"
            style="aspect-ratio: 16/9; contain: layout; border-radius: 8px;"
          >
            <Image
              src={edgeServerImage}
              alt="A high-performance compact edge AI server with glowing blue LED indicators, designed for secure local deployment of large language models in enterprise environments."
              class="rounded-lg w-full h-full object-cover"
              widths={[400, 600, 800]}
              fetchpriority="high"
              loading="eager"
              width={1376}
              height={768}
              style="aspect-ratio: 16/9; border-radius: 8px;"
            />
          </div>
          <p class="text-center text-sm text-muted dark:text-gray-400 mt-3">
            LocalAI Agent — High-performance edge AI server for enterprise deployment
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Vision Section **************** -->

  <section
    class="relative py-16 md:py-24 overflow-hidden bg-transparent"
    style="min-height: 500px; contain: layout style;"
  >
    <!-- Enhanced Background - Ceramic gradient -->
    <div
      class="absolute inset-0 bg-gradient-to-br from-ceramic/50 via-white/30 to-ceramic/50 dark:from-obsidian/50 dark:via-gray-950/30 dark:to-obsidian/50 backdrop-blur-sm"
    >
    </div>

    <!-- Grid pattern overlay -->
    <div
      class="absolute inset-0 opacity-[0.03] dark:opacity-[0.05]"
      style="background-image: linear-gradient(#007AFF 1px, transparent 1px), linear-gradient(90deg, #007AFF 1px, transparent 1px); background-size: 60px 60px;"
    >
    </div>

    <!-- Floating decorative elements with neon glow -->
    <div
      class="absolute top-20 left-10 w-16 h-16 bg-gradient-to-br from-klein/15 to-electric-cyan/15 rounded-full blur-xl animate-float neon-glow"
    >
    </div>
    <div
      class="absolute bottom-20 right-10 w-20 h-20 bg-gradient-to-tr from-purple-500/15 to-klein/15 rounded-full blur-xl animate-float-delayed neon-glow-blue"
    >
    </div>

    <!-- Background Image with placeholder -->
    <div class="absolute inset-0 pointer-events-none" style="min-height: 500px; contain: layout;">
      <div class="absolute inset-0 bg-gradient-to-b from-transparent to-ceramic/80 dark:to-obsidian/80 z-10"></div>
      <div
        class="absolute inset-0 bg-gradient-to-br from-ceramic/50 to-white/50 dark:from-obsidian/10 dark:to-gray-900/10"
      >
      </div>
      <Image
        src={dataPrivacyImage}
        alt="A 3D isometric illustration of a digital fortress dome protecting local enterprise servers from external cloud data leaks, representing private and secure AI infrastructure."
        class="w-full h-full object-cover opacity-40 dark:opacity-50"
        widths={[800, 1200]}
        loading="lazy"
        fetchpriority="low"
        width={1920}
        height={1080}
        style="aspect-ratio: 16/9; min-height: 500px;"
      />
    </div>

    <div class="container-max mx-auto px-4 relative z-20">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl md:text-5xl font-bold mb-8 text-charcoal dark:text-white" style="letter-spacing: -0.022em;">
          The Future of Enterprise AI is Local
        </h2>
        <div
          class="space-y-6 text-lg md:text-xl text-secondary dark:text-gray-300 glass-card p-8 md:p-10 rounded-3xl shadow-deep border border-border"
          style="line-height: 1.5; border-radius: 8px;"
        >
          <p>Cloud AI is powerful, but enterprises need more control over their data and infrastructure.</p>
          <p>
            LocalAI Agent empowers businesses to deploy AI models locally and run enterprise-grade AI agents for secure,
            private, and efficient workflows.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- What We Are Building ********** -->

  <Features
    title="What We Are Building"
    subtitle="Building the future of enterprise AI with local deployment and intelligent automation"
    columns={3}
    items={[
      {
        title: 'Local AI Deployment',
        description: 'Run advanced AI models directly on your own infrastructure for full control and privacy.',
        icon: 'tabler:server',
      },
      {
        title: 'Enterprise AI Agents',
        description: 'Intelligent agents that automate workflows and interact with your internal systems.',
        icon: 'tabler:robot',
      },
      {
        title: 'Hardware & Software',
        description: 'A complete stack optimized for reliable and efficient local AI deployment.',
        icon: 'tabler:cpu',
      },
    ]}
  />

  <!-- Why Local AI ****************** -->

  <section class="relative py-16 md:py-24 bg-transparent overflow-hidden">
    <!-- Enhanced background with cyber lines -->
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-ceramic/30 to-transparent dark:via-obsidian/20">
    </div>
    <div class="absolute inset-0 cyber-lines opacity-20 dark:opacity-40"></div>

    <div class="container-max mx-auto px-4 relative z-10">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-12">
          <h2
            class="text-3xl md:text-5xl font-bold mb-4 text-charcoal dark:text-white"
            style="letter-spacing: -0.022em;"
          >
            Why Local AI?
          </h2>
          <p class="text-lg md:text-xl text-secondary dark:text-gray-300">
            Take control of your AI infrastructure and data
          </p>
        </div>

        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <!-- Left: Benefits List -->
          <div class="space-y-6">
            <div
              class="group flex items-start space-x-4 p-6 rounded-2xl glass-card border border-border shadow-soft hover:shadow-deep transition-all duration-300 hover:-translate-y-1"
              style="border-radius: 8px;"
            >
              <div
                class="flex-shrink-0 w-14 h-14 rounded-full bg-gradient-to-br from-klein to-electric-cyan flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform duration-300"
                style="border-radius: 50%;"
              >
                <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
                  ></path>
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-semibold mb-2 text-charcoal dark:text-white" style="letter-spacing: -0.022em;">
                  Data Privacy & Security
                </h3>
                <p class="text-secondary dark:text-gray-300">
                  Keep sensitive enterprise data inside your organization.
                </p>
              </div>
            </div>

            <div
              class="group flex items-start space-x-4 p-6 rounded-2xl glass-card border border-border shadow-soft hover:shadow-deep transition-all duration-300 hover:-translate-y-1"
              style="border-radius: 8px;"
            >
              <div
                class="flex-shrink-0 w-14 h-14 rounded-full bg-gradient-to-br from-klein to-electric-cyan flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform duration-300"
                style="border-radius: 50%;"
              >
                <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"
                  ></path>
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-semibold mb-2 text-charcoal dark:text-white" style="letter-spacing: -0.022em;">
                  Low Latency
                </h3>
                <p class="text-secondary dark:text-gray-300">Immediate AI responses without cloud dependency.</p>
              </div>
            </div>

            <div
              class="group flex items-start space-x-4 p-6 rounded-2xl glass-card border border-border shadow-soft hover:shadow-deep transition-all duration-300 hover:-translate-y-1"
              style="border-radius: 8px;"
            >
              <div
                class="flex-shrink-0 w-14 h-14 rounded-full bg-gradient-to-br from-klein to-electric-cyan flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform duration-300"
                style="border-radius: 50%;"
              >
                <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"
                  ></path>
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-semibold mb-2 text-charcoal dark:text-white" style="letter-spacing: -0.022em;">
                  Full Infrastructure Control
                </h3>
                <p class="text-secondary dark:text-gray-300">Customize your AI environment for your business.</p>
              </div>
            </div>

            <div
              class="group flex items-start space-x-4 p-6 rounded-2xl glass-card border border-border shadow-soft hover:shadow-deep transition-all duration-300 hover:-translate-y-1"
              style="border-radius: 8px;"
            >
              <div
                class="flex-shrink-0 w-14 h-14 rounded-full bg-gradient-to-br from-klein to-electric-cyan flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform duration-300"
                style="border-radius: 50%;"
              >
                <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"
                  ></path>
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-semibold mb-2 text-charcoal dark:text-white" style="letter-spacing: -0.022em;">
                  No Cloud Dependency
                </h3>
                <p class="text-secondary dark:text-gray-300">Reduce costs and risks of cloud-based AI.</p>
              </div>
            </div>
          </div>

          <!-- Right: Comparison Image with glassmorphism -->
          <div class="relative">
            <div
              class="relative glass-card rounded-lg shadow-deep mx-auto lg:mx-0 md:min-h-[300px]"
              style="aspect-ratio: 4/3; border-radius: 8px;"
            >
              <Image
                src={latencyImage}
                alt="A conceptual speed comparison diagram showing the ultra-low latency of local AI model inference versus the high-latency path of cloud-based AI processing."
                class="rounded-lg w-full h-full object-cover"
                widths={[400, 600, 800]}
                width={800}
                height={600}
                style="aspect-ratio: 4/3; border-radius: 8px;"
                loading="lazy"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Detailed FAQ Section ********** -->

  <section class="py-16 md:py-24 bg-white/50 dark:bg-gray-900/50 backdrop-blur-md">
    <div class="container-max mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2
          class="text-3xl md:text-4xl font-bold mb-4 text-center text-charcoal dark:text-white"
          style="letter-spacing: -0.022em;"
        >
          Frequently Asked Questions
        </h2>
        <p class="text-lg text-secondary dark:text-gray-300 mb-12 text-center">
          Get answers to common questions about LocalAI Agent and local AI deployment.
        </p>

        <div class="space-y-6">
          <div class="glass-card dark:bg-card-dark rounded-xl p-6 shadow-soft" style="border-radius: 8px;">
            <h3 class="text-xl font-semibold mb-3 text-charcoal dark:text-white" style="letter-spacing: -0.022em;">
              What is LocalAI Agent?
            </h3>
            <p class="text-secondary dark:text-gray-300">
              LocalAI Agent is an enterprise solution that helps organizations deploy AI models locally and run
              enterprise-grade AI agents on their own infrastructure, ensuring data privacy, security, and low-latency
              inference.
            </p>
          </div>

          <div class="glass-card dark:bg-card-dark rounded-xl p-6 shadow-soft" style="border-radius: 8px;">
            <h3 class="text-xl font-semibold mb-3 text-charcoal dark:text-white" style="letter-spacing: -0.022em;">
              Why deploy AI models locally?
            </h3>
            <p class="text-secondary dark:text-gray-300">
              Local AI deployment provides complete data privacy, reduced latency, lower costs, and full control over
              your AI infrastructure. It eliminates dependency on cloud providers and keeps sensitive enterprise data
              within your organization.
            </p>
          </div>

          <div class="glass-card dark:bg-card-dark rounded-xl p-6 shadow-soft" style="border-radius: 8px;">
            <h3 class="text-xl font-semibold mb-3 text-charcoal dark:text-white" style="letter-spacing: -0.022em;">
              What AI models are supported?
            </h3>
            <p class="text-secondary dark:text-gray-300">
              LocalAI Agent supports open-source LLMs including Llama, Mistral, Falcon, and other transformer-based
              models. Our platform is model-agnostic and optimized for enterprise deployment.
            </p>
          </div>

          <div class="glass-card dark:bg-card-dark rounded-xl p-6 shadow-soft" style="border-radius: 8px;">
            <h3 class="text-xl font-semibold mb-3 text-charcoal dark:text-white" style="letter-spacing: -0.022em;">
              What are the hardware requirements?
            </h3>
            <p class="text-secondary dark:text-gray-300">
              For 7B models, you need 8GB VRAM. For 14B models, plan for 12-16GB VRAM. NVIDIA GPUs (RTX 3090/4090 or
              A100) are recommended for best performance.
            </p>
          </div>

          <div class="glass-card dark:bg-card-dark rounded-xl p-6 shadow-soft" style="border-radius: 8px;">
            <h3 class="text-xl font-semibold mb-3 text-charcoal dark:text-white" style="letter-spacing: -0.022em;">
              How is data security ensured?
            </h3>
            <p class="text-secondary dark:text-gray-300">
              All AI processing happens on your infrastructure. Your data never leaves your network, ensuring compliance
              with GDPR, HIPAA, and SOC 2.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stay Connected Section ******* -->

  <section class="py-16 md:py-24 bg-transparent">
    <div class="container-max mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold mb-6 text-charcoal dark:text-white" style="letter-spacing: -0.022em;">
          Stay Connected
        </h2>
        <p class="text-lg text-secondary dark:text-gray-300 mb-10">
          Follow us on GitHub and Twitter to track our progress. Join our community soon on Discord and Reddit.
        </p>
        <div class="flex justify-center items-center space-x-6">
          <a
            href="https://github.com/LocalAI-Agent"
            target="_blank"
            rel="noopener noreferrer"
            class="text-secondary dark:text-gray-300 hover:text-klein dark:hover:text-electric-cyan nav-hover-neon transition-colors"
            aria-label="GitHub"
          >
            <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path
                fill-rule="evenodd"
                d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                clip-rule="evenodd"></path>
            </svg>
          </a>
          <a
            href="https://twitter.com/localai67177"
            target="_blank"
            rel="noopener noreferrer"
            class="text-secondary dark:text-gray-300 hover:text-klein dark:hover:text-electric-cyan nav-hover-neon transition-colors"
            aria-label="Twitter"
          >
