---
import Layout from '~/layouts/PageLayout.astro';
import { getPermalink } from '~/utils/permalinks';

import Hero from '~/components/widgets/Hero.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

import Features2 from '~/components/widgets/Features2.astro';
import Features from '~/components/widgets/Features.astro';
import Stats from '~/components/widgets/Stats.astro';
import Features3 from '~/components/widgets/Features3.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Brands from '~/components/widgets/Brands.astro';

import { YouTube } from 'astro-embed';

const metadata = {
  title: 'LocalAI-Agent - Intelligent Technology Solutions',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="Welcome"
    actions={[
      {
        variant: 'primary',
        text: 'Get Started',
        href: getPermalink('/services'),
      },
      { text: 'Learn More', href: '#features' },
    ]}
  >
    <Fragment slot="title">
      Empower Your Business Growth with <span class="text-accent dark:text-white">Artificial Intelligence</span>
    </Fragment>

    <Fragment slot="subtitle">
      LocalAI-Agent provides cutting-edge AI solutions to help businesses achieve digital transformation, improve operational efficiency, and create greater business value.
    </Fragment>

    <Fragment slot="image">
      <YouTube id="gxBkghlglTg" title="Astro just Launched.... Could it be the ultimate web framework?" />
      <style is:inline>
        lite-youtube {
          margin: 0 auto;
          max-width: 100%;
        }
      </style>
    </Fragment>
  </Hero>

  <!-- Features2 Widget ************** -->

  <Features2
    title="About Us"
    subtitle="LocalAI-Agent is committed to providing leading AI solutions for enterprises. Our team consists of experienced engineers and data scientists focused on transforming cutting-edge technology into practical business applications, helping clients maintain competitive advantages in digital transformation."
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- Stats Widget ****************** -->

  <Stats
    title="Your Trusted Technology Partner"
    subtitle="Our results demonstrate the trust our clients have placed in us and the exceptional value we've helped them achieve."
    stats={[
      { title: 'Enterprises Served', amount: '200+' },
      { title: 'Projects Delivered', amount: '500+' },
      { title: 'Customer Satisfaction', amount: '98%' },
      { title: 'Technical Support', amount: '24/7' },
    ]}
  />

  <!-- Brands Widget ****************** -->

  <Brands
    title="Our Partners"
    subtitle="We collaborate with industry-leading companies to drive technological innovation."
    icons={[]}
    images={[
      {
        src: 'https://cdn.pixabay.com/photo/2015/04/23/17/41/node-js-736399_1280.png',
        alt: 'Node JS',
      },
      {
        src: 'https://cdn.pixabay.com/photo/2015/10/31/12/54/google-1015751_1280.png',
        alt: 'Google',
      },
      {
        src: 'https://cdn.pixabay.com/photo/2021/12/06/13/45/meta-6850393_1280.png',
        alt: 'Meta',
      },
      {
        src: 'https://cdn.pixabay.com/photo/2013/02/12/09/07/microsoft-80658_1280.png',
        alt: 'Microsoft',
      },
    ]}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="Our Services"
    subtitle="Comprehensive AI technology solutions for enterprises"
    items={[
      {
        title: 'AI Consulting',
        description:
          'Professional AI consulting services to help evaluate business scenarios and develop AI implementation strategies.',
        icon: 'flat-color-icons:document',
      },
      {
        title: 'Custom Development',
        description:
          'Customized AI model development and system integration services based on your specific business needs.',
        icon: 'flat-color-icons:template',
      },
      {
        title: 'Technical Support & Training',
        description:
          'Comprehensive technical support and team training to ensure smooth operation and continuous optimization of AI systems.',
        icon: 'flat-color-icons:voice-presentation',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- Features Widget *************** -->

  <Features
    id="features"
    title="Core Advantages"
    subtitle="Our technology and services feature the following characteristics"
    columns={3}
    items={[
      {
        title: 'Advanced Technology Architecture',
        description:
          'Utilizing the latest AI technologies and architecture to ensure system performance and technical leadership.',
        icon: 'tabler:artboard',
      },
      {
        title: 'Flexible Deployment Options',
        description: 'Supporting cloud, on-premise, and hybrid deployment to meet different enterprise security and compliance requirements.',
        icon: 'tabler:picture-in-picture',
      },
      {
        title: 'Highly Customizable',
        description:
          'Customize features and interfaces based on specific business needs, perfectly matching your business processes.',
        icon: 'tabler:adjustments-horizontal',
      },
      {
        title: 'Fast Integration',
        description: 'Providing comprehensive APIs and SDKs for quick integration with existing systems.',
        icon: 'tabler:rocket',
      },
      {
        title: 'Data Security',
        description:
          'Enterprise-grade security measures to ensure data privacy and compliance.',
        icon: 'tabler:arrows-right-left',
      },
      {
        title: 'Wide Compatibility',
        description: 'Compatible with mainstream technology stacks and platforms, reducing the barrier to use.',
        icon: 'tabler:plug-connected',
      },
    ]}
  />

  <!-- FAQs Widget ******************* -->

  <FAQs
    title="Frequently Asked Questions"
    items={[
      {
        title: 'What services do you provide?',
        description:
          'We provide comprehensive services including AI consulting, custom development, system integration, and technical training. From needs assessment to implementation, from deployment to ongoing maintenance, we accompany you throughout your AI transformation journey.',
      },
      {
        title: 'How do we get started?',
        description:
          'You can start by contacting our sales team. We will arrange a professional technical consultant to communicate with you, understand your needs, and provide a customized solution and quotation.',
      },
      {
        title: 'What is the project timeline?',
        description:
          'The project timeline depends on specific requirements and scale. Simple integration projects may take 2-4 weeks, while complex custom development may take 2-6 months. We will provide you with a detailed timeline after evaluation.',
      },
      {
        title: 'What deployment options do you support?',
        description:
          'We support multiple deployment options including public cloud, private cloud, on-premise deployment, and hybrid deployment. You can choose the most suitable solution based on security requirements and business needs.',
      },
      {
        title: 'Do you provide after-sales support?',
        description:
          'Yes, we provide comprehensive after-sales support including technical support, system maintenance, feature upgrades, and performance optimization. We also offer SLA service guarantees.',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </FAQs>

  <!-- Features3 Widget ************** -->

  <Features3
    title="Contact Us"
    subtitle="We're here to answer any questions you may have."
    columns={4}
    items={[
      {
        title: 'Phone',
        icon: 'tabler:phone',
        callToAction: {
          text: 'Call Us',
          href: getPermalink('/contact'),
          variant: 'link',
        },
      },
      {
        title: 'Email',
        icon: 'tabler:mail',
        callToAction: {
          text: 'Send Email',
          href: 'mailto:info@localai-agent.com',
          variant: 'link',
        },
      },
      {
        title: 'Online Chat',
        icon: 'tabler:message-circle',
        callToAction: {
          text: 'Start Chat',
          href: getPermalink('/contact'),
          variant: 'link',
        },
      },
      {
        title: 'Technical Support',
        icon: 'tabler:headset',
        callToAction: {
          text: 'Get Help',
          href: getPermalink('/contact'),
          variant: 'link',
        },
      },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Get Started',
        href: getPermalink('/contact'),
      },
    ]}
  >
    <Fragment slot="title">Join Us in Shaping the Future</Fragment>

    <Fragment slot="subtitle">
      Contact us today to get your customized solution and start your AI transformation journey.
    </Fragment>
  </CallToAction>
</Layout>
