---
import Layout from '~/layouts/PageLayout.astro';
import { Image } from 'astro:assets';

import ContactUs from '~/components/widgets/Contact.astro';
import StructuredData from '~/components/common/StructuredData.astro';

// Import images
import contactHeroImage from '~/assets/images/local-ai-server-infrastructure-hero.webp';

const metadata = {
  title: 'Contact PrivOcto - Get in Touch for Enterprise AI Solutions',
  description: 'Contact PrivOcto for enterprise AI inquiries and support. We respond within 24 hours.',
};

const faqs = [
  {
    question: 'What enterprise AI solutions do you offer?',
    answer:
      'We provide local AI infrastructure deployment, enterprise AI agents, and customized AI solutions for businesses.',
  },
  {
    question: 'How quickly do you respond to inquiries?',
    answer:
      'Our team typically responds within 24 business hours. For urgent matters, we offer priority support packages.',
  },
  {
    question: 'Do you offer custom AI deployments?',
    answer:
      'Yes, we specialize in custom AI deployments tailored to your enterprise infrastructure and security requirements.',
  },
];
---

<StructuredData type="organization" />
<StructuredData type="faq" faqs={faqs} />

<style is:global>
  @keyframes gradient {
    0% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
    100% {
      background-position: 0% 50%;
    }
  }

  .animate-gradient {
    background-size: 200% 200%;
    animation: gradient 3s ease infinite;
  }
</style>

<Layout metadata={metadata}>
  <!-- Hero Section -->
  <section
    class="relative py-20 md:py-32 overflow-hidden bg-page dark:bg-dark"
    style="min-height: 700px; contain: layout style;"
  >
    <!-- Enhanced Background - Ceramic White to White gradient -->
    <div
      class="absolute inset-0 bg-gradient-to-br from-ceramic via-white to-ceramic dark:from-obsidian dark:via-gray-950 dark:to-obsidian animate-gradient-slow"
      style="background-size: 200% 200%;"
    >
    </div>

    <!-- Cyber glow lines - Dark mode data flow -->
    <div class="absolute inset-0 cyber-lines opacity-30 dark:opacity-60"></div>

    <!-- Decorative floating orbs with fresnel effect -->
    <div
      class="absolute -top-40 -right-40 w-80 h-80 bg-gradient-to-br from-klein/20 to-electric-cyan/20 rounded-full blur-3xl animate-float fresnel-light"
    >
    </div>
    <div
      class="absolute -bottom-40 -left-40 w-80 h-80 bg-gradient-to-tr from-purple-500/20 to-klein/20 rounded-full blur-3xl animate-float-delayed fresnel-light"
    >
    </div>

    <div class="container-max mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="grid lg:grid-cols-2 gap-12 items-center grid-gutter">
        <!-- Left: Content -->
        <div class="text-center lg:text-left" style="contain: layout;">
          <p class="text-base text-klein dark:text-electric-cyan font-bold tracking-widest uppercase mb-4 animate-fade">
            Get in Touch
          </p>
          <h1
            class="text-5xl md:text-7xl font-bold leading-tighter tracking-tight mb-6 text-charcoal dark:text-white"
            style="letter-spacing: -0.022em;"
          >
            Let's Connect!
          </h1>
          <p
            class="text-xl md:text-2xl text-secondary dark:text-gray-300 mb-8 max-w-2xl mx-auto lg:mx-0 leading-relaxed"
            style="line-height: 1.5;"
          >
            Have questions about enterprise AI deployment? We're here to help you build the future of local AI
            infrastructure.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start items-center">
            <a
              href="#form"
              class="group inline-flex items-center justify-center px-8 py-4 text-base font-semibold rounded-lg text-white bg-klein hover:bg-blue-700 transition-all duration-300 shadow-soft hover:shadow-neon-blue hover:-translate-y-0.5"
              style="border-radius: 8px;"
            >
              Send a Message
              <svg
                class="ml-2 w-5 h-5 group-hover:translate-x-1 transition-transform"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"
                ></path>
              </svg>
            </a>
            <a
              href="mailto:server@privocto.com"
              class="group inline-flex items-center justify-center px-8 py-4 text-base font-semibold rounded-lg text-charcoal dark:text-white bg-white/70 dark:bg-gray-800/70 backdrop-blur-md border border-border hover:bg-white dark:hover:bg-gray-700 transition-all duration-300 shadow-soft hover:shadow-md hover:-translate-y-0.5"
              style="border-radius: 8px;"
            >
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                ></path>
              </svg>
              Email Us
            </a>
          </div>
        </div>

        <!-- Right: Image with glassmorphism -->
        <div class="relative" style="contain: layout;">
          <div
            class="relative glass-card rounded-lg shadow-deep"
            style="aspect-ratio: 16/9; min-height: 400px; contain: layout; border-radius: 8px;"
          >
            <Image
              src={contactHeroImage}
              alt="A high-performance enterprise edge server rack inside a modern, secure server room."
              class="rounded-lg w-full h-full object-cover"
              widths={[400, 600, 800]}
              fetchpriority="high"
              loading="eager"
              width={1920}
              height={1080}
              style="aspect-ratio: 16/9; border-radius: 8px;"
            />
          </div>
          <p class="text-center text-sm text-muted dark:text-gray-400 mt-3">
            PrivOcto — Enterprise AI infrastructure ready for your business
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Form Section -->
  <section
    id="form"
    class="relative py-16 md:py-24 overflow-hidden bg-page dark:bg-dark noise-texture"
    style="contain: layout style;"
  >
    <!-- Enhanced Background -->
    <div
      class="absolute inset-0 bg-gradient-to-br from-ceramic/80 via-white/50 to-ceramic/80 dark:from-obsidian/80 dark:via-gray-950/50 dark:to-obsidian/80"
    >
    </div>

    <!-- Grid pattern overlay -->
    <div
      class="absolute inset-0 opacity-[0.03] dark:opacity-[0.05]"
      style="background-image: linear-gradient(#007AFF 1px, transparent 1px), linear-gradient(90deg, #007AFF 1px, transparent 1px); background-size: 60px 60px;"
    >
    </div>

    <!-- Floating decorative elements -->
    <div
      class="absolute top-20 left-10 w-16 h-16 bg-gradient-to-br from-klein/15 to-electric-cyan/15 rounded-full blur-xl animate-float neon-glow"
    >
    </div>
    <div
      class="absolute bottom-20 right-10 w-20 h-20 bg-gradient-to-tr from-purple-500/15 to-klein/15 rounded-full blur-xl animate-float-delayed neon-glow-blue"
    >
    </div>

    <div class="container-max mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <ContactUs
        title="Drop us a message today!"
        subtitle="For quicker answers, explore our FAQs section. You may find the solution you're looking for right there! If not, our support team is delighted to help you."
        formAction={import.meta.env.FORMSPREE_ENDPOINT}
        inputs={[
          {
            type: 'text',
            name: 'name',
            label: 'Name',
          },
          {
            type: 'email',
            name: 'email',
            label: 'Email',
          },
        ]}
        textarea={{
          label: 'Message',
        }}
        disclaimer={{
          label:
            'By submitting this contact form, you acknowledge and agree to the collection of your personal information.',
        }}
        description="Our support team typically responds within 24 business hours."
      />
    </div>
  </section>

  <!-- Contact Information Section -->
  <section class="relative py-16 md:py-24 overflow-hidden bg-alt noise-texture">
    <!-- Enhanced Background -->
    <div
      class="absolute inset-0 bg-gradient-to-br from-ceramic/50 via-white/30 to-ceramic/50 dark:from-obsidian/50 dark:via-gray-950/30 dark:to-obsidian/50"
    >
    </div>

    <div class="container-max mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="max-w-6xl mx-auto">
        <h2
          class="text-3xl md:text-5xl font-bold mb-4 text-center text-charcoal dark:text-white"
          style="letter-spacing: -0.022em;"
        >
          We are here to help!
        </h2>
        <p class="text-lg md:text-xl text-secondary dark:text-gray-300 text-center mb-12 leading-relaxed">
          Choose the best way to reach us
        </p>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          <!-- General Support -->
          <div
            class="group glass-card rounded-2xl p-6 border border-border shadow-soft hover:shadow-deep transition-all duration-300 hover:-translate-y-1"
            style="border-radius: 8px;"
          >
            <div class="flex items-center mb-4">
              <div
                class="w-14 h-14 rounded-full bg-gradient-to-br from-klein to-electric-cyan flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform duration-300"
                style="border-radius: 50%;"
              >
                <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"
                  ></path>
                </svg>
              </div>
            </div>
            <h3 class="text-xl font-semibold mb-3 text-charcoal dark:text-white" style="letter-spacing: -0.022em;">
              General Support
            </h3>
            <p class="text-secondary dark:text-gray-300 leading-relaxed">
              Chat with us for help with: Account management, Website navigation, Payment issues, Template access,
              General questions.
            </p>
          </div>

          <!-- Contact Sales -->
          <div
            class="group glass-card rounded-2xl p-6 border border-border shadow-soft hover:shadow-deep transition-all duration-300 hover:-translate-y-1"
            style="border-radius: 8px;"
          >
            <div class="flex items-center mb-4">
              <div
                class="w-14 h-14 rounded-full bg-gradient-to-br from-klein to-electric-cyan flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform duration-300"
                style="border-radius: 50%;"
              >
                <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                  ></path>
                </svg>
              </div>
            </div>
            <h3 class="text-xl font-semibold mb-3 text-charcoal dark:text-white" style="letter-spacing: -0.022em;">
              Contact Sales
            </h3>
            <p class="text-secondary dark:text-gray-300 leading-relaxed">
              Chat with us about: Purchases, Customization, Commercial licensing, Template questions.
            </p>
          </div>

          <!-- Technical Support -->
          <div
            class="group glass-card rounded-2xl p-6 border border-border shadow-soft hover:shadow-deep transition-all duration-300 hover:-translate-y-1"
            style="border-radius: 8px;"
          >
            <div class="flex items-center mb-4">
              <div
                class="w-14 h-14 rounded-full bg-gradient-to-br from-klein to-electric-cyan flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform duration-300"
                style="border-radius: 50%;"
              >
                <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"
                  ></path>
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
              </div>
            </div>
            <h3 class="text-xl font-semibold mb-3 text-charcoal dark:text-white" style="letter-spacing: -0.022em;">
              Technical Support
            </h3>
            <p class="text-secondary dark:text-gray-300 leading-relaxed">
              Chat with us for technical help: Template installation, Editing problems, Software compatibility, Download
              errors, Other technical issues.
            </p>
          </div>

          <!-- Phone -->
          <div
            class="group glass-card rounded-2xl p-6 border border-border shadow-soft hover:shadow-deep transition-all duration-300 hover:-translate-y-1"
            style="border-radius: 8px;"
          >
            <div class="flex items-center mb-4">
              <div
                class="w-14 h-14 rounded-full bg-gradient-to-br from-klein to-electric-cyan flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform duration-300"
                style="border-radius: 50%;"
              >
                <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                  ></path>
                </svg>
              </div>
            </div>
            <h3 class="text-xl font-semibold mb-3 text-charcoal dark:text-white" style="letter-spacing: -0.022em;">
              Phone
            </h3>
            <p class="text-secondary dark:text-gray-300 leading-relaxed">+1 (234) 567-890</p>
          </div>

          <!-- Email -->
          <div
            class="group glass-card rounded-2xl p-6 border border-border shadow-soft hover:shadow-deep transition-all duration-300 hover:-translate-y-1"
            style="border-radius: 8px;"
          >
            <div class="flex items-center mb-4">
              <div
                class="w-14 h-14 rounded-full bg-gradient-to-br from-klein to-electric-cyan flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform duration-300"
                style="border-radius: 50%;"
              >
                <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                  ></path>
                </svg>
              </div>
            </div>
            <h3 class="text-xl font-semibold mb-3 text-charcoal dark:text-white" style="letter-spacing: -0.022em;">
              Email
            </h3>
            <p class="text-secondary dark:text-gray-300 leading-relaxed">server@privocto.com</p>
          </div>

          <!-- Location -->
          <div
            class="group glass-card rounded-2xl p-6 border border-border shadow-soft hover:shadow-deep transition-all duration-300 hover:-translate-y-1"
            style="border-radius: 8px;"
          >
            <div class="flex items-center mb-4">
              <div
                class="w-14 h-14 rounded-full bg-gradient-to-br from-klein to-electric-cyan flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform duration-300"
                style="border-radius: 50%;"
              >
                <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
              </div>
            </div>
            <h3 class="text-xl font-semibold mb-3 text-charcoal dark:text-white" style="letter-spacing: -0.022em;">
              Location
            </h3>
            <p class="text-secondary dark:text-gray-300 leading-relaxed">1234 Lorem Ipsum St, 12345, Miami, EEUU</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Additional Resources Section -->
  <section class="relative py-16 md:py-24 overflow-hidden bg-page dark:bg-dark noise-texture">
    <!-- Enhanced Background -->
    <div
      class="absolute inset-0 bg-gradient-to-br from-ceramic/80 via-white/50 to-ceramic/80 dark:from-obsidian/80 dark:via-gray-950/50 dark:to-obsidian/80"
    >
    </div>

    <div class="container-max mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl md:text-5xl font-bold mb-6 text-charcoal dark:text-white" style="letter-spacing: -0.022em;">
          Additional Resources
        </h2>
        <p class="text-xl text-secondary dark:text-gray-300 mb-12 leading-relaxed">
          Explore more about PrivOcto and our community
        </p>

        <div class="grid md:grid-cols-3 gap-6">
          <!-- Blog Link -->
          <a
            href="/blog"
            class="group glass-card rounded-2xl p-6 border border-border shadow-soft hover:shadow-deep transition-all duration-300 hover:-translate-y-1 text-center"
            style="border-radius: 8px;"
          >
            <div class="flex items-center justify-center mb-4">
              <div
                class="w-16 h-16 rounded-full bg-gradient-to-br from-klein to-electric-cyan flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform duration-300"
                style="border-radius: 50%;"
              >
                <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"
                  ></path>
                </svg>
              </div>
            </div>
            <h3 class="text-xl font-semibold mb-2 text-charcoal dark:text-white" style="letter-spacing: -0.022em;">
              Blog
            </h3>
            <p class="text-secondary dark:text-gray-300 leading-relaxed">
              Read our latest articles about local AI deployment and best practices.
            </p>
          </a>

          <!-- About Link -->
          <a
            href="/about"
            class="group glass-card rounded-2xl p-6 border border-border shadow-soft hover:shadow-deep transition-all duration-300 hover:-translate-y-1 text-center"
            style="border-radius: 8px;"
          >
            <div class="flex items-center justify-center mb-4">
              <div
                class="w-16 h-16 rounded-full bg-gradient-to-br from-klein to-electric-cyan flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform duration-300"
                style="border-radius: 50%;"
              >
                <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
            </div>
            <h3 class="text-xl font-semibold mb-2 text-charcoal dark:text-white" style="letter-spacing: -0.022em;">
              About Us
            </h3>
            <p class="text-secondary dark:text-gray-300 leading-relaxed">
              Learn more about our mission and vision for enterprise AI.
            </p>
          </a>

          <!-- GitHub Link -->
          <a
            href="https://github.com/PrivOcto"
            target="_blank"
            rel="noopener noreferrer"
            class="group glass-card rounded-2xl p-6 border border-border shadow-soft hover:shadow-deep transition-all duration-300 hover:-translate-y-1 text-center"
            style="border-radius: 8px;"
          >
            <div class="flex items-center justify-center mb-4">
              <div
                class="w-16 h-16 rounded-full bg-gradient-to-br from-klein to-electric-cyan flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform duration-300"
                style="border-radius: 50%;"
              >
                <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24">
                  <path
                    d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                  ></path>
                </svg>
              </div>
            </div>
            <h3 class="text-xl font-semibold mb-2 text-charcoal dark:text-white" style="letter-spacing: -0.022em;">
              GitHub
            </h3>
            <p class="text-secondary dark:text-gray-300 leading-relaxed">
              Follow our open source projects and contribute to PrivOcto.
            </p>
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
