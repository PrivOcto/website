---
import Layout from '~/layouts/PageLayout.astro';
import Features from '~/components/widgets/Features.astro';

const metadata = {
  title: 'About LocalAI Agent',
};
---

<Layout metadata={metadata}>
  <!-- Hero Section ******************* -->

  <section class="py-20 md:py-32">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-6 gradient-text">
          About LocalAI Agent
        </h1>
        <p class="text-xl text-gray-600 dark:text-gray-300 mb-8">
          LocalAI Agent is building the next generation of enterprise AI infrastructure.
          We help organizations deploy AI models locally and run enterprise-grade AI agents directly on their own infrastructure.
        </p>
        <p class="text-lg text-gray-600 dark:text-gray-300">
          By combining optimized hardware, local AI models, and intelligent agents, we enable businesses to build powerful AI systems while maintaining full control over their data and environment.
        </p>
        <p class="text-lg text-gray-600 dark:text-gray-300 mt-6 font-semibold">
          Our mission is to make secure, private, and efficient AI deployment accessible to enterprises.
        </p>
      </div>
    </div>
  </section>

  <!-- Our Vision Section ************ -->

  <section class="py-16 md:py-24 bg-white dark:bg-gray-900 glass-card">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold mb-8 text-center gradient-text">
          Our Vision
        </h2>
        <p class="text-xl text-gray-600 dark:text-gray-300 text-center mb-8">
          The future of enterprise AI is local, secure, and controllable.
        </p>
        <div class="space-y-6 text-lg text-gray-600 dark:text-gray-300">
          <p>
            While cloud AI services are powerful, many organizations require stronger guarantees around data privacy, security, and infrastructure control. Sensitive business data cannot always be sent to external cloud providers.
          </p>
          <p>
            LocalAI Agent aims to solve this challenge by enabling companies to run AI where their data lives.
          </p>
        </div>
        
        <div class="mt-12 grid md:grid-cols-2 gap-6">
          <div class="glass-card rounded-xl p-6 holo-card cyber-border">
            <div class="flex items-center mb-4">
              <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center mr-4">
                <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
              </div>
              <h3 class="text-xl font-semibold">Deploy AI models locally</h3>
            </div>
            <p class="text-gray-600 dark:text-gray-300 ml-16">
              Keep sensitive data inside your infrastructure
            </p>
          </div>
          
          <div class="glass-card rounded-xl p-6 holo-card cyber-border">
            <div class="flex items-center mb-4">
              <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center mr-4">
                <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <h3 class="text-xl font-semibold">Run intelligent AI agents</h3>
            </div>
            <p class="text-gray-600 dark:text-gray-300 ml-16">
              Automate workflows while maintaining full control
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What We Do Section ************ -->

  <Features
    title="What We Do"
    subtitle="LocalAI Agent provides a complete stack for enterprise local AI deployment"
    columns={3}
    items={[
      {
        title: 'Local AI Infrastructure',
        description: 'We provide optimized hardware solutions designed to run modern AI models efficiently on-premise.',
        icon: 'tabler:server',
      },
      {
        title: 'Local AI Model Deployment',
        description: 'We deploy and configure AI models directly on enterprise infrastructure, ensuring reliable and secure AI operations.',
        icon: 'tabler:cpu',
      },
      {
        title: 'Enterprise AI Agents',
        description: 'Our enterprise-grade agents automate business workflows and interact with internal systems, all running locally without relying on external cloud services.',
        icon: 'tabler:robot',
      },
    ]}
  />

  <!-- Why Local AI Section ********** -->

  <section class="py-16 md:py-24 bg-gray-50 dark:bg-gray-800">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold mb-8 text-center gradient-text">
          Why Local AI
        </h2>
        <p class="text-xl text-gray-600 dark:text-gray-300 text-center mb-12">
          Running AI locally provides critical advantages for enterprises:
        </p>
        
        <div class="grid md:grid-cols-2 gap-6">
          <div class="glass-card rounded-xl p-6 holo-card">
            <div class="flex items-center mb-4">
              <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center mr-4">
                <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                </svg>
              </div>
              <h3 class="text-xl font-semibold">Data Privacy</h3>
            </div>
            <p class="text-gray-600 dark:text-gray-300 ml-16">
              Sensitive business data stays within your organization.
            </p>
          </div>
          
          <div class="glass-card rounded-xl p-6 holo-card">
            <div class="flex items-center mb-4">
              <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center mr-4">
                <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
              </div>
              <h3 class="text-xl font-semibold">Security</h3>
            </div>
            <p class="text-gray-600 dark:text-gray-300 ml-16">
              AI systems run inside your own infrastructure.
            </p>
          </div>
          
          <div class="glass-card rounded-xl p-6 holo-card">
            <div class="flex items-center mb-4">
              <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center mr-4">
                <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
              </div>
              <h3 class="text-xl font-semibold">Low Latency</h3>
            </div>
            <p class="text-gray-600 dark:text-gray-300 ml-16">
              Local inference provides faster responses and more reliable performance.
            </p>
          </div>
          
          <div class="glass-card rounded-xl p-6 holo-card">
            <div class="flex items-center mb-4">
              <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center mr-4">
                <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <h3 class="text-xl font-semibold">Full Control</h3>
            </div>
            <p class="text-gray-600 dark:text-gray-300 ml-16">
              Organizations maintain full control over their AI stack and deployment.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Approach Section ********** -->

  <section class="py-16 md:py-24 bg-white dark:bg-gray-900 glass-card">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold mb-8 text-center gradient-text">
          Our Approach
        </h2>
        <p class="text-xl text-gray-600 dark:text-gray-300 text-center mb-12">
          LocalAI Agent combines hardware, software, and intelligent agents into a unified solution for enterprise AI.
        </p>
        
        <div class="grid md:grid-cols-2 gap-6 mb-12">
          <div class="flex items-start space-x-4">
            <div class="flex-shrink-0 w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-semibold mb-1">Reliable AI infrastructure</h3>
            </div>
          </div>
          
          <div class="flex items-start space-x-4">
            <div class="flex-shrink-0 w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-semibold mb-1">Secure local model deployment</h3>
            </div>
          </div>
          
          <div class="flex items-start space-x-4">
            <div class="flex-shrink-0 w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-semibold mb-1">Scalable enterprise agents</h3>
            </div>
          </div>
          
          <div class="flex items-start space-x-4">
            <div class="flex-shrink-0 w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-semibold mb-1">Seamless integration with business systems</h3>
            </div>
          </div>
        </div>
        
        <p class="text-lg text-gray-600 dark:text-gray-300 text-center">
          This integrated architecture allows companies to deploy AI systems that are secure, efficient, and tailored to their needs.
        </p>
      </div>
    </div>
  </section>
</Layout>
