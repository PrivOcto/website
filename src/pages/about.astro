---
import Layout from '~/layouts/PageLayout.astro';
import { Image } from 'astro:assets';

// Import images
import heroImage from '~/assets/images/local-ai-server-infrastructure-hero.webp';
import fortressImage from '~/assets/images/secure-digital-ai-fortress-concept.webp';
import workflowImage from '~/assets/images/enterprise-ai-agent-workflow-interface.webp';
import landscapeImage from '~/assets/images/integrated-ai-hardware-landscape.webp';

const metadata = {
  title: 'About PrivOcto - Enterprise AI Infrastructure Mission',
  description: 'Learn about PrivOcto mission to provide secure, private enterprise AI infrastructure.',
};
---

<style is:global>
  @keyframes gradient {
    0% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
    100% {
      background-position: 0% 50%;
    }
  }

  .animate-gradient {
    background-size: 200% 200%;
    animation: gradient 3s ease infinite;
  }
</style>

<Layout metadata={metadata}>
  <!-- Hero Section ******************* -->

  <section class="relative py-20 md:py-32 overflow-hidden">
    <!-- Enhanced Background -->
    <div
      class="absolute inset-0 bg-gradient-to-br from-blue-50/80 via-cyan-50/50 to-blue-50/80 dark:from-blue-950/80 dark:via-cyan-950/50 dark:to-blue-950/80 animate-gradient-slow"
      style="background-size: 200% 200%;"
    >
    </div>

    <!-- Floating decorative orbs -->
    <div
      class="absolute -top-40 -right-40 w-80 h-80 bg-gradient-to-br from-blue-400/20 to-cyan-400/20 rounded-full blur-3xl animate-float"
    >
    </div>
    <div
      class="absolute -bottom-40 -left-40 w-80 h-80 bg-gradient-to-tr from-purple-400/20 to-blue-400/20 rounded-full blur-3xl animate-float-delayed"
    >
    </div>

    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <!-- Left: Content -->
        <div class="text-center lg:text-left">
          <h1
            class="text-5xl md:text-7xl font-bold leading-tighter tracking-tighter mb-6 bg-gradient-to-r from-blue-600 via-cyan-500 to-blue-600 bg-clip-text text-transparent animate-gradient-slow drop-shadow-lg"
            style="background-size: 200% 200%;"
          >
            About PrivOcto
          </h1>
          <p class="text-lg md:text-xl text-gray-600 dark:text-gray-300 leading-relaxed">
            We help businesses deploy AI on their own infrastructure. Our solution combines optimized hardware, local AI
            models, and intelligent agents.
          </p>
          <p class="text-lg md:text-xl text-gray-600 dark:text-gray-300 mt-6 font-semibold leading-relaxed">
            You keep full control over your data. Your AI systems stay secure and private.
          </p>
        </div>

        <!-- Right: Image -->
        <div class="relative px-4 group">
          <div
            class="relative rounded-2xl overflow-hidden shadow-2xl transform transition-all duration-500 group-hover:scale-[1.02] group-hover:shadow-blue-500/20"
          >
            <div
              class="absolute inset-0 bg-gradient-to-br from-blue-500/10 to-cyan-500/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500"
            >
            </div>
            <Image
              src={heroImage}
              alt="A high-performance, compact enterprise edge server rack inside a modern, secure server room."
              class="w-full h-auto"
              width={1920}
              height={1080}
              sizes="100vw"
              style={{ objectFit: 'cover', height: '500px' }}
              fetchpriority="high"
              loading="eager"
            />
          </div>
          <p class="text-center text-sm text-gray-500 dark:text-gray-400 mt-4">
            PrivOcto — High-performance enterprise edge infrastructure
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Vision Section ************ -->

  <section class="relative py-16 md:py-24 overflow-hidden">
    <!-- Enhanced Background -->
    <div
      class="absolute inset-0 bg-gradient-to-br from-blue-50/50 via-cyan-50/30 to-blue-50/50 dark:from-blue-950/50 dark:via-cyan-950/30 dark:to-blue-950/50"
    >
    </div>

    <!-- Grid pattern overlay -->
    <div
      class="absolute inset-0 opacity-[0.03] dark:opacity-[0.05]"
      style="background-image: linear-gradient(#3b82f6 1px, transparent 1px), linear-gradient(90deg, #3b82f6 1px, transparent 1px); background-size: 60px 60px;"
    >
    </div>

    <!-- Floating decorative elements -->
    <div
      class="absolute top-20 left-10 w-16 h-16 bg-gradient-to-br from-blue-400/15 to-cyan-400/15 rounded-full blur-xl animate-float"
    >
    </div>
    <div
      class="absolute bottom-20 right-10 w-20 h-20 bg-gradient-to-tr from-purple-400/15 to-blue-400/15 rounded-full blur-xl animate-float-delayed"
    >
    </div>

    <!-- Background Image with enhanced overlay -->
    <div class="absolute inset-0 pointer-events-none">
      <div
        class="absolute inset-0 bg-gradient-to-b from-white/80 via-white/50 to-white/80 dark:from-blue-950/80 dark:via-blue-950/50 dark:to-blue-950/80"
      >
      </div>
      <Image
        src={fortressImage}
        alt="A 3D isometric visualization of a secure, private digital vault protecting a network of AI data nodes."
        class="w-full h-full object-cover opacity-30 dark:opacity-40"
        width={1920}
        height={1080}
        sizes="100vw"
        style={{ objectFit: 'cover', height: '500px' }}
      />
    </div>

    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="max-w-4xl mx-auto text-center" style="margin-top: -120px;">
        <h2
          class="text-3xl md:text-5xl font-bold mb-8 bg-gradient-to-r from-blue-600 via-cyan-500 to-blue-600 bg-clip-text text-transparent animate-gradient-slow drop-shadow-lg"
          style="background-size: 200% 200%;"
        >
          Our Vision
        </h2>
        <p class="text-xl md:text-2xl text-gray-600 dark:text-gray-300 text-center mb-8 font-medium leading-relaxed">
          The future of enterprise AI is local, secure, and controllable.
        </p>
        <div
          class="space-y-6 text-lg md:text-xl text-gray-600 dark:text-gray-300 bg-white/70 dark:bg-gray-800/70 backdrop-blur-md p-8 md:p-10 rounded-3xl shadow-xl border border-white/20 dark:border-gray-700/30"
        >
          <p class="leading-relaxed">Cloud AI services are powerful. But many organizations need more control over:</p>
        </div>
      </div>
    </div>
  </section>

  <!-- What We Do Section ************ -->

  <section class="relative py-16 md:py-24 overflow-hidden">
    <!-- Enhanced Background -->
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-blue-50/30 to-transparent dark:via-blue-950/20">
    </div>
    <div
      class="absolute inset-0 opacity-[0.02] dark:opacity-[0.04]"
      style="background-image: linear-gradient(#3b82f6 1px, transparent 1px), linear-gradient(90deg, #3b82f6 1px, transparent 1px); background-size: 80px 80px;"
    >
    </div>

    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="max-w-6xl mx-auto">
        <h2
          class="text-3xl md:text-5xl font-bold mb-8 text-center bg-gradient-to-r from-blue-600 via-cyan-500 to-blue-600 bg-clip-text text-transparent animate-gradient-slow drop-shadow-lg"
          style="background-size: 200% 200%;"
        >
          What We Do
        </h2>

        <div class="grid lg:grid-cols-2 gap-12 items-center mb-12">
          <!-- 3. Workflow Image: Beside What We Do Text -->
          <div class="group order-2 lg:order-1">
            <div
              class="relative rounded-2xl overflow-hidden shadow-xl transform transition-all duration-500 group-hover:scale-[1.02] group-hover:shadow-blue-500/20"
            >
              <div
                class="absolute inset-0 bg-gradient-to-br from-blue-500/10 to-cyan-500/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500"
              >
              </div>
              <Image
                src={workflowImage}
                alt="A professional engineer working on a high-tech dashboard displaying autonomous AI agent workflows."
                class="w-full"
                width={1920}
                height={1080}
                sizes="100vw"
                style={{ objectFit: 'cover', height: '500px' }}
              />
            </div>
            <p class="text-center text-sm text-gray-500 dark:text-gray-400 mt-4">
              PrivOcto — Enterprise AI agent workflow management
            </p>
          </div>

          <!-- Text Content -->
          <div class="space-y-6 order-1 lg:order-2">
            <p class="text-lg md:text-xl text-gray-600 dark:text-gray-300 leading-relaxed">
              PrivOcto provides a complete stack for enterprise local AI deployment.
            </p>

            <div class="space-y-4">
              <div
                class="group flex items-start space-x-4 p-4 rounded-2xl bg-white/60 dark:bg-gray-800/60 backdrop-blur-md border border-white/20 dark:border-gray-700/30 shadow-md hover:shadow-xl transition-all duration-300 hover:-translate-y-1"
              >
                <div
                  class="flex-shrink-0 w-12 h-12 rounded-full bg-gradient-to-br from-blue-500 to-cyan-500 flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform duration-300"
                >
                  <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="text-lg font-semibold mb-1 text-gray-900 dark:text-white">Local AI Infrastructure</h3>
                  <p class="text-gray-600 dark:text-gray-300">
                    We provide optimized hardware for running AI models on-premise.
                  </p>
                </div>
              </div>

              <div
                class="group flex items-start space-x-4 p-4 rounded-2xl bg-white/60 dark:bg-gray-800/60 backdrop-blur-md border border-white/20 dark:border-gray-700/30 shadow-md hover:shadow-xl transition-all duration-300 hover:-translate-y-1"
              >
                <div
                  class="flex-shrink-0 w-12 h-12 rounded-full bg-gradient-to-br from-blue-500 to-cyan-500 flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform duration-300"
                >
                  <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="text-lg font-semibold mb-1 text-gray-900 dark:text-white">Local AI Model Deployment</h3>
                  <p class="text-gray-600 dark:text-gray-300">
                    We deploy AI models on your infrastructure. Your operations stay secure and reliable.
                  </p>
                </div>
              </div>

              <div
                class="group flex items-start space-x-4 p-4 rounded-2xl bg-white/60 dark:bg-gray-800/60 backdrop-blur-md border border-white/20 dark:border-gray-700/30 shadow-md hover:shadow-xl transition-all duration-300 hover:-translate-y-1"
              >
                <div
                  class="flex-shrink-0 w-12 h-12 rounded-full bg-gradient-to-br from-blue-500 to-cyan-500 flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform duration-300"
                >
                  <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="text-lg font-semibold mb-1 text-gray-900 dark:text-white">Enterprise AI Agents</h3>
                  <p class="text-gray-600 dark:text-gray-300">
                    Our agents automate business workflows. They run locally without cloud services.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Local AI Section ********** -->

  <section class="relative py-16 md:py-24 overflow-hidden">
    <!-- Enhanced Background -->
    <div
      class="absolute inset-0 bg-gradient-to-br from-blue-50/50 via-cyan-50/30 to-blue-50/50 dark:from-blue-950/50 dark:via-cyan-950/30 dark:to-blue-950/50"
    >
    </div>
    <div
      class="absolute inset-0 opacity-[0.02] dark:opacity-[0.04]"
      style="background-image: linear-gradient(#3b82f6 1px, transparent 1px), linear-gradient(90deg, #3b82f6 1px, transparent 1px); background-size: 60px 60px;"
    >
    </div>

    <!-- Floating decorative elements -->
    <div
      class="absolute top-40 right-20 w-24 h-24 bg-gradient-to-br from-blue-400/15 to-cyan-400/15 rounded-full blur-xl animate-float"
    >
    </div>
    <div
      class="absolute bottom-40 left-20 w-20 h-20 bg-gradient-to-tr from-purple-400/15 to-blue-400/15 rounded-full blur-xl animate-float-delayed"
    >
    </div>

    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="max-w-4xl mx-auto">
        <h2
          class="text-3xl md:text-5xl font-bold mb-8 text-center bg-gradient-to-r from-blue-600 via-cyan-500 to-blue-600 bg-clip-text text-transparent animate-gradient-slow drop-shadow-lg"
          style="background-size: 200% 200%;"
        >
          Why Local AI
        </h2>
        <p class="text-xl md:text-2xl text-gray-600 dark:text-gray-300 text-center mb-12 leading-relaxed">
          Running AI locally provides critical advantages for enterprises:
        </p>

        <div class="grid md:grid-cols-2 gap-6">
          <div
            class="group glass-card rounded-2xl p-6 holo-card hover:shadow-xl transition-all duration-300 hover:-translate-y-1 bg-white/70 dark:bg-gray-800/70 backdrop-blur-md border border-white/20 dark:border-gray-700/30"
          >
            <div class="flex items-center mb-4">
              <div
                class="w-14 h-14 rounded-full bg-gradient-to-br from-blue-500 to-cyan-500 flex items-center justify-center mr-4 shadow-lg group-hover:scale-110 transition-transform duration-300"
              >
                <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
                  ></path>
                </svg>
              </div>
              <h3 class="text-xl font-semibold text-gray-900 dark:text-white">Data Privacy</h3>
            </div>
            <p class="text-gray-600 dark:text-gray-300 ml-20 leading-relaxed">
              Sensitive business data stays within your organization.
            </p>
          </div>

          <div
            class="group glass-card rounded-2xl p-6 holo-card hover:shadow-xl transition-all duration-300 hover:-translate-y-1 bg-white/70 dark:bg-gray-800/70 backdrop-blur-md border border-white/20 dark:border-gray-700/30"
          >
            <div class="flex items-center mb-4">
              <div
                class="w-14 h-14 rounded-full bg-gradient-to-br from-blue-500 to-cyan-500 flex items-center justify-center mr-4 shadow-lg group-hover:scale-110 transition-transform duration-300"
              >
                <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
                  ></path>
                </svg>
              </div>
              <h3 class="text-xl font-semibold text-gray-900 dark:text-white">Security</h3>
            </div>
            <p class="text-gray-600 dark:text-gray-300 ml-20 leading-relaxed">
              AI systems run inside your own infrastructure.
            </p>
          </div>

          <div
            class="group glass-card rounded-2xl p-6 holo-card hover:shadow-xl transition-all duration-300 hover:-translate-y-1 bg-white/70 dark:bg-gray-800/70 backdrop-blur-md border border-white/20 dark:border-gray-700/30"
          >
            <div class="flex items-center mb-4">
              <div
                class="w-14 h-14 rounded-full bg-gradient-to-br from-blue-500 to-cyan-500 flex items-center justify-center mr-4 shadow-lg group-hover:scale-110 transition-transform duration-300"
              >
                <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"
                  ></path>
                </svg>
              </div>
              <h3 class="text-xl font-semibold text-gray-900 dark:text-white">Low Latency</h3>
            </div>
            <p class="text-gray-600 dark:text-gray-300 ml-20 leading-relaxed">
              Local inference provides faster responses and more reliable performance.
            </p>
          </div>

          <div
            class="group glass-card rounded-2xl p-6 holo-card hover:shadow-xl transition-all duration-300 hover:-translate-y-1 bg-white/70 dark:bg-gray-800/70 backdrop-blur-md border border-white/20 dark:border-gray-700/30"
          >
            <div class="flex items-center mb-4">
              <div
                class="w-14 h-14 rounded-full bg-gradient-to-br from-blue-500 to-cyan-500 flex items-center justify-center mr-4 shadow-lg group-hover:scale-110 transition-transform duration-300"
              >
                <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"
                  ></path>
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
              </div>
              <h3 class="text-xl font-semibold text-gray-900 dark:text-white">Full Control</h3>
            </div>
            <p class="text-gray-600 dark:text-gray-300 ml-20 leading-relaxed">
              Organizations maintain full control over their AI stack and deployment.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Approach Section ********** -->

  <section class="py-16 md:py-24 bg-card glass-card">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold mb-8 text-center gradient-text">Our Approach</h2>
        <p class="text-xl text-gray-600 dark:text-gray-300 text-center mb-12">
          PrivOcto combines hardware, software, and intelligent agents into a unified solution for enterprise AI.
        </p>

        <div class="grid md:grid-cols-2 gap-6 mb-12">
          <div class="flex items-start space-x-4">
            <div class="flex-shrink-0 w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-semibold mb-1">Reliable AI infrastructure</h3>
            </div>
          </div>

          <div class="flex items-start space-x-4">
            <div class="flex-shrink-0 w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-semibold mb-1">Secure local model deployment</h3>
            </div>
          </div>

          <div class="flex items-start space-x-4">
            <div class="flex-shrink-0 w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-semibold mb-1">Scalable enterprise agents</h3>
            </div>
          </div>

          <div class="flex items-start space-x-4">
            <div class="flex-shrink-0 w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-semibold mb-1">Seamless integration with business</h3>
            </div>
          </div>
        </div>

        <p class="text-lg text-gray-600 dark:text-gray-300 text-center mb-12">
          This integrated architecture allows companies to deploy AI systems that are secure, efficient, and tailored to
          their needs.
        </p>

        <!-- CTA Links Section -->
        <div class="grid md:grid-cols-3 gap-6 mb-12">
          <!-- Contact Link -->
          <a
            href="/contact"
            class="glass-card rounded-xl p-6 holo-card hover:scale-105 transition-transform text-center"
          >
            <div class="flex items-center justify-center mb-4">
              <svg class="w-12 h-12 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                ></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold mb-2">Contact Us</h3>
            <p class="text-gray-600 dark:text-gray-300">Get in touch with our team to learn more.</p>
          </a>

          <!-- Blog Link -->
          <a href="/blog" class="glass-card rounded-xl p-6 holo-card hover:scale-105 transition-transform text-center">
            <div class="flex items-center justify-center mb-4">
              <svg class="w-12 h-12 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"
                ></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold mb-2">Blog</h3>
