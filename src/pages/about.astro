---
import Features from '~/components/widgets/Features.astro';
import Hero from '~/components/widgets/Hero.astro';
import Layout from '~/layouts/PageLayout.astro';
import { getPermalink } from '~/utils/permalinks';

const metadata = {
  title: 'About LocalAI Agent',
};
---

<Layout metadata={metadata}>
  <!-- Hero Section ******************* -->

  <Hero
    tagline="About Us"
  >
    <Fragment slot="title">
      About LocalAI Agent
    </Fragment>

    <Fragment slot="subtitle">
      Empowering enterprises with secure, private, and efficient AI solutions through local deployment and intelligent agents.
    </Fragment>
  </Hero>

  <!-- Our Mission Section *********** -->

  <section class="py-16 md:py-24 bg-white dark:bg-gray-900">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold mb-8 text-center">
          Empowering Enterprises with Local AI
        </h2>
        <div class="space-y-6 text-lg text-gray-600 dark:text-gray-300">
          <p>
            At LocalAI Agent, we believe that enterprises should have full control over their AI. Cloud AI is powerful, but sensitive business data and critical workflows often require secure, private, and low-latency solutions.
          </p>
          <p>
            Our mission is to enable businesses to deploy AI models locally and run enterprise-grade AI agents that streamline operations while keeping data safe.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Vision Section ************ -->

  <section class="py-16 md:py-24 bg-gray-50 dark:bg-gray-800">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold mb-8 text-center">
          The Future of Enterprise AI is Local
        </h2>
        <div class="space-y-6 text-lg text-gray-600 dark:text-gray-300">
          <p>
            We envision a world where organizations can harness AI without compromising privacy or control. By combining local AI deployment with intelligent agents, companies can automate complex workflows, improve efficiency, and unlock the full potential of their data—all on their own infrastructure.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- What We Build Section ********* -->

  <Features
    title="What We Are Building"
    subtitle="Building enterprise-grade AI solutions for local deployment"
    columns={3}
    items={[
      {
        title: 'Local AI Deployment',
        description: 'Run powerful AI models securely on your own infrastructure.',
        icon: 'tabler:server',
      },
      {
        title: 'Enterprise AI Agents',
        description: 'Intelligent agents that automate workflows and integrate with internal systems.',
        icon: 'tabler:robot',
      },
      {
        title: 'Integrated Hardware & Software',
        description: 'Optimized stacks for reliable and efficient local AI operations.',
        icon: 'tabler:cpu',
      },
    ]}
  >
    <Fragment slot="after">
      <p class="text-center text-gray-600 dark:text-gray-400 mt-8 max-w-3xl mx-auto">
        Even though we are currently building, our focus is always on enterprise reliability, security, and performance.
      </p>
    </Fragment>
  </Features>

  <!-- Our Team Section ************** -->

  <section class="py-16 md:py-24 bg-white dark:bg-gray-900">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold mb-8 text-center">
          The Team Behind LocalAI Agent
        </h2>
        <div class="grid md:grid-cols-3 gap-8">
          <div class="text-center">
            <div class="w-24 h-24 mx-auto mb-4 rounded-full bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center text-white text-2xl font-bold">
              CEO
            </div>
            <h3 class="text-xl font-semibold mb-2">Founder / CEO</h3>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-3">AI & Enterprise Software</p>
            <p class="text-gray-600 dark:text-gray-300">
              AI & enterprise software veteran with 10+ years of experience building scalable systems.
            </p>
          </div>
          <div class="text-center">
            <div class="w-24 h-24 mx-auto mb-4 rounded-full bg-gradient-to-br from-green-500 to-teal-600 flex items-center justify-center text-white text-2xl font-bold">
              CTO
            </div>
            <h3 class="text-xl font-semibold mb-2">CTO / Lead Engineer</h3>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-3">AI Infrastructure Expert</p>
            <p class="text-gray-600 dark:text-gray-300">
              Expert in computer vision, deep learning, and AI infrastructure.
            </p>
          </div>
          <div class="text-center">
            <div class="w-24 h-24 mx-auto mb-4 rounded-full bg-gradient-to-br from-orange-500 to-red-600 flex items-center justify-center text-white text-2xl font-bold">
              Product
            </div>
            <h3 class="text-xl font-semibold mb-2">Product & Design Lead</h3>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-3">Enterprise UX</p>
            <p class="text-gray-600 dark:text-gray-300">
              Focused on building intuitive, enterprise-ready AI solutions.
            </p>
          </div>
        </div>
        <p class="text-center text-gray-600 dark:text-gray-400 mt-10 text-lg">
          Our team combines AI research, engineering expertise, and enterprise experience to build solutions that matter.
        </p>
      </div>
    </div>
  </section>

  <!-- Our Values Section ************ -->

  <Features
    title="What Drives Us"
    subtitle="Core values that guide every decision we make"
    columns={2}
    items={[
      {
        title: 'Privacy First',
        description: 'Data security is at the core of every decision.',
        icon: 'tabler:shield-lock',
      },
      {
        title: 'Reliability',
        description: 'Enterprise-grade AI must always perform.',
        icon: 'tabler:check',
      },
      {
        title: 'Innovation',
        description: 'We build the future of local AI infrastructure.',
        icon: 'tabler:bulb',
      },
      {
        title: 'Transparency',
        description: 'Open communication with our early users and partners.',
        icon: 'tabler:eye',
      },
    ]}
  />

  <!-- Connect Section *************** -->

  <section class="py-16 md:py-24 bg-gray-50 dark:bg-gray-800">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold mb-6">
          Join Our Early Access & Community
        </h2>
        <p class="text-lg text-gray-600 dark:text-gray-300 mb-10">
          Follow us on GitHub and Twitter to track progress. Soon, join our community on Discord and Reddit to engage directly with our team and early users.
        </p>
        <div class="flex justify-center items-center space-x-6">
          <a 
            href="https://github.com/LocalAI-Agent" 
            target="_blank" 
            rel="noopener noreferrer"
            class="group flex flex-col items-center text-gray-600 dark:text-gray-300 hover:text-primary dark:hover:text-blue-400 transition-colors"
            aria-label="GitHub"
          >
            <svg class="w-12 h-12 mb-2" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
            </svg>
            <span class="text-sm font-medium">GitHub</span>
          </a>
          <a 
            href="https://twitter.com/LocalAI-Agent" 
            target="_blank" 
            rel="noopener noreferrer"
            class="group flex flex-col items-center text-gray-600 dark:text-gray-300 hover:text-primary dark:hover:text-blue-400 transition-colors"
            aria-label="Twitter"
          >
            <svg class="w-12 h-12 mb-2" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
            </svg>
            <span class="text-sm font-medium">Twitter</span>
          </a>
          <span class="group flex flex-col items-center text-gray-400 dark:text-gray-500" title="Coming soon" aria-label="Discord - Coming soon">
            <svg class="w-12 h-12 mb-2 opacity-50" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
            </svg>
            <span class="text-sm font-medium">Discord</span>
            <span class="text-xs text-gray-500">(soon)</span>
          </span>
          <span class="group flex flex-col items-center text-gray-400 dark:text-gray-500" title="Coming soon" aria-label="Reddit - Coming soon">
            <svg class="w-12 h-12 mb-2 opacity-50" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 0 1 .042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 0 1 4.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 0 1 .14-.197.35.35 0 0 1 .238-.042l2.906.617a1.214 1.214 0 0 1 1.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 0 0-.231.094.33.33 0 0 0 0 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 0 0 .029-.463.33.33 0 0 0-.464 0c-.547.533-1.684.73-2.512.73-.828 0-1.979-.196-2.512-.73a.326.326 0 0 0-.232-.095z"/>
            </svg>
            <span class="text-sm font-medium">Reddit</span>
            <span class="text-xs text-gray-500">(soon)</span>
          </span>
        </div>
      </div>
    </div>
  </section>
</Layout>
