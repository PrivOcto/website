---
import '@fontsource-variable/inter';

// 'DM Sans'
// Nunito
// Dosis
// Outfit
// Roboto
// Literata
// 'IBM Plex Sans'
// Karla
// Poppins
// 'Fira Sans'
// 'Libre Franklin'
// Inconsolata
// Raleway
// Oswald
// 'Space Grotesk'
// Urbanist
---

<style is:inline>
  /* Override font-face with font-display: swap to eliminate FOIT */
  @font-face {
    font-family: 'Inter Variable';
    font-style: normal;
    font-display: fallback;
    font-weight: 100 900;
    src: url('/_astro/inter-latin-wght-normal.Dx4kXJAl.woff2') format('woff2-variations');
    unicode-range: U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD;
  }

  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(1 97 239);
    --aw-color-secondary: rgb(1 84 207);
    --aw-color-accent: rgb(109 40 217);

    --aw-color-text-heading: rgb(0 0 0);
    --aw-color-text-default: rgb(16 16 16);
    --aw-color-text-muted: rgb(16 16 16 / 66%);

    /* Light Mode - "Pure White Canvas"
       Clean, minimal, professional */
    --aw-color-bg-page: rgb(255 255 255);
    --aw-color-bg-page-dark: rgb(0 0 0);
    --aw-color-bg-card: rgb(255 255 255);
    --aw-color-bg-card-dark: rgb(0 0 0);
    --aw-color-bg-alt: rgb(248 249 250);
    --aw-color-bg-alt-dark: rgb(8 10 12);

    ::selection {
      background-color: rgba(1, 97, 239, 0.15);
      color: rgb(1 97 239);
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(1 97 239);
    --aw-color-secondary: rgb(1 84 207);
    --aw-color-accent: rgb(109 40 217);

    --aw-color-text-heading: rgb(248 250 252);
    --aw-color-text-default: rgb(226 232 240);
    --aw-color-text-muted: rgb(226 232 240 / 60%);

    /* Dark Mode - "True Black Void"
       Deep, immersive, modern */
    --aw-color-bg-page: rgb(0 0 0);
    --aw-color-bg-card: rgb(0 0 0);
    --aw-color-bg-card-dark: rgb(8 10 12);
    --aw-color-bg-alt: rgb(8 10 12);
    --aw-color-bg-alt-dark: rgb(0 0 0);

    ::selection {
      background-color: rgba(1, 97, 239, 0.35);
      color: rgb(96 165 250);
    }
  }
</style>
