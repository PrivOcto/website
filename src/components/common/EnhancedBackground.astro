---
/**
 * EnhancedBackground - Decorative background component with animations
 * Zero performance impact - uses CSS-only animations
 */

interface Props {
  variant?: 'gradient' | 'grid' | 'particles' | 'waves';
  className?: string;
}

const { variant = 'gradient', className = '' } = Astro.props;
---

<div class={`absolute inset-0 overflow-hidden pointer-events-none ${className}`}>
  {variant === 'gradient' && (
    <>
      <!-- Animated gradient orbs -->
      <div class="absolute -top-40 -right-40 w-80 h-80 bg-gradient-to-br from-blue-400/20 to-cyan-400/20 rounded-full blur-3xl animate-float"></div>
      <div class="absolute -bottom-40 -left-40 w-80 h-80 bg-gradient-to-tr from-purple-400/20 to-blue-400/20 rounded-full blur-3xl animate-float-delayed"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-gradient-to-r from-cyan-400/10 to-blue-400/10 rounded-full blur-3xl animate-pulse-slow"></div>
    </>
  )}

  {variant === 'grid' && (
    <>
      <!-- Subtle grid pattern -->
      <div class="absolute inset-0 opacity-[0.02] dark:opacity-[0.05]" style="background-image: linear-gradient(#3b82f6 1px, transparent 1px), linear-gradient(90deg, #3b82f6 1px, transparent 1px); background-size: 40px 40px;"></div>
      <!-- Gradient overlay -->
      <div class="absolute inset-0 bg-gradient-to-b from-transparent via-blue-50/30 to-transparent dark:via-blue-900/10"></div>
    </>
  )}

  {variant === 'particles' && (
    <>
      <!-- CSS-only floating particles -->
      <div class="absolute top-1/4 left-1/4 w-2 h-2 bg-blue-400/30 rounded-full animate-float"></div>
      <div class="absolute top-3/4 left-1/3 w-1.5 h-1.5 bg-cyan-400/30 rounded-full animate-float-delayed"></div>
      <div class="absolute top-1/3 right-1/4 w-2.5 h-2.5 bg-purple-400/20 rounded-full animate-float"></div>
      <div class="absolute bottom-1/4 right-1/3 w-2 h-2 bg-blue-400/25 rounded-full animate-float-delayed"></div>
      <div class="absolute top-1/2 right-1/4 w-1.5 h-1.5 bg-cyan-400/30 rounded-full animate-float"></div>
    </>
  )}

  {variant === 'waves' && (
    <>
      <!-- Wave patterns using SVG -->
      <svg class="absolute bottom-0 left-0 right-0 h-32 text-blue-100/50 dark:text-blue-900/20" viewBox="0 0 1440 320" preserveAspectRatio="none">
        <path fill="currentColor" fill-opacity="1" d="M0,160L48,176C96,192,192,224,288,213.3C384,203,480,149,576,138.7C672,128,768,160,864,186.7C960,213,1056,235,1152,218.7C1248,203,1344,149,1392,122.7L1440,96L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path>
      </svg>
      <svg class="absolute bottom-0 left-0 right-0 h-24 text-cyan-100/40 dark:text-cyan-900/15" viewBox="0 0 1440 320" preserveAspectRatio="none" style="transform: translateY(20px);">
        <path fill="currentColor" fill-opacity="1" d="M0,224L48,213.3C96,203,192,181,288,181.3C384,181,480,203,576,208C672,213,768,203,864,181.3C960,160,1056,128,1152,128C1248,128,1344,160,1392,176L1440,192L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path>
      </svg>
    </>
  )}
</div>
