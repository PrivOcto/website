---
import { Icon } from 'astro-icon/components';

import Image from '~/components/common/Image.astro';
import PostTags from '~/components/blog/Tags.astro';
import SocialShare from '~/components/common/SocialShare.astro';

import { getPermalink } from '~/utils/permalinks';
import { getFormattedDate } from '~/utils/utils';

import type { Post } from '~/types';

export interface Props {
  post: Post;
  url: string | URL;
}

const { post, url } = Astro.props;
---

<section class="mx-auto">
  <article class="relative">
    <header>
      <div class="flex justify-between flex-col sm:flex-row max-w-3xl mx-auto mt-0 mb-2 px-4 sm:px-6 sm:items-center">
        <p class="flex flex-wrap items-center gap-2 text-sm text-gray-600 dark:text-gray-400">
          <span class="flex items-center gap-1">
            <Icon name="tabler:clock" class="w-4 h-4" />
            <time datetime={String(post.publishDate)}>{getFormattedDate(post.publishDate)}</time>
          </span>
          {
            post.author && (
              <span class="flex items-center gap-1">
                · <Icon name="tabler:user" class="w-4 h-4" />
                <span>{post.author}</span>
              </span>
            )
          }
          {
            post.category && (
              <span>
                ·{' '}
                <a class="hover:text-primary transition-colors" href={getPermalink(post.category.slug, 'category')}>
                  {post.category.title}
                </a>
              </span>
            )
          }
          {
            post.readingTime && (
              <span>
                · <span>{post.readingTime}</span> min read
              </span>
            )
          }
        </p>
      </div>

      <h1
        class="sr-only"
        class:list={[
          'px-4 sm:px-6 max-w-3xl mx-auto text-4xl md:text-5xl font-bold leading-tighter tracking-tighter font-heading',
        ]}
      >
        {post.title}
      </h1>
      <p
        class="max-w-3xl mx-auto mt-4 mb-2 px-4 sm:px-6 text-xl md:text-2xl text-muted dark:text-slate-400 text-justify leading-relaxed"
      >
        {post.excerpt}
      </p>

      {
        post.image ? (
          <div class="group max-w-3xl mx-auto mt-2 px-4 sm:px-6">
            <div class="relative rounded-2xl overflow-hidden shadow-lg transform transition-all duration-500 group-hover:scale-[1.02] group-hover:shadow-blue-500/20">
              <div class="absolute inset-0 bg-gradient-to-br from-blue-500/10 to-cyan-500/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500" />
              <Image
                src={post.image}
                class="w-full bg-gray-400 dark:bg-slate-700"
                widths={[400, 900]}
                sizes="(max-width: 900px) 400px, 900px"
                alt={post?.excerpt || ''}
                width={900}
                height={506}
                loading="eager"
                decoding="async"
                fetchpriority="high"
                aspectRatio="16/9"
              />
            </div>
          </div>
        ) : (
          <div class="max-w-3xl mx-auto px-4 sm:px-6">
            <div class="border-t dark:border-slate-700" />
          </div>
        )
      }
    </header>
    <div
      style="margin-top: 0;"
      class="mx-auto px-6 sm:px-6 max-w-3xl prose prose-md lg:prose-xl dark:prose-invert dark:prose-headings:text-slate-300 prose-headings:font-heading prose-headings:leading-tighter prose-headings:tracking-tighter prose-headings:font-bold prose-a:text-primary dark:prose-a:text-blue-400 prose-img:rounded-md prose-img:shadow-lg prose-headings:scroll-mt-[80px] prose-li:my-0 [&>:first-child]:mt-0 [&>h1:first-child]:mt-0 [&>h1:first-child]:mb-6"
    >
      <slot />
    </div>
    <div class="mx-auto px-6 sm:px-6 max-w-3xl mt-8 flex justify-between flex-col sm:flex-row">
      <PostTags tags={post.tags} class="mr-5 rtl:mr-0 rtl:ml-5" />
      <SocialShare url={url} text={post.title} class="mt-5 sm:mt-1 align-middle text-gray-500 dark:text-slate-600" />
    </div>
  </article>
</section>
