---
import icon_webp from '~/assets/favicons/icon.webp';
import icon_png from '~/assets/favicons/icon.png';
---

<link rel="shortcut icon" href={icon_webp} type="image/webp" />
<link rel="icon" type="image/webp" href={icon_webp} />
<link rel="icon" type="image/png" sizes="32x32" href={icon_png} />
<link rel="apple-touch-icon" sizes="180x180" href={icon_webp } />
