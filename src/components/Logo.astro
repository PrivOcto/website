---
import Image from 'astro/components/Image.astro';
import { SITE } from 'astrowind:config';
import logoIcon from '~/assets/favicons/icon.webp';
---

<span
  class="self-center ml-2 rtl:ml-0 rtl:mr-2 text-2xl md:text-xl font-bold text-gray-900 whitespace-nowrap dark:text-white"
>
  <Image src={logoIcon} alt="Logo" width={128} height={128} class="w-32 h-32 inline-block align-middle" />
  {SITE?.name}
</span>
