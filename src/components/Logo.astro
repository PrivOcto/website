---
import Image from 'astro/components/Image.astro';
import { SITE } from 'astrowind:config';
import logoIcon from '~/assets/favicons/icon.webp';
---

<a
  class="self-center ml-2 rtl:ml-0 rtl:mr-2 text-2xl md:text-xl font-bold text-gray-900 whitespace-nowrap dark:text-white flex items-center gap-2"
  href="/"
  aria-label="PrivOcto Home"
>
  <Image
    src={logoIcon}
    alt="Logo"
    width={160}
    height={160}
    fetchpriority="high"
    class="w-20 h-20 inline-block align-middle"
    sizes="80px"
  />
  <span>{SITE?.name}</span>
</a>
